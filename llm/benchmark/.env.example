# Core Test Configuration
TEST_ACCOUNT=test_account_id
TEST_USER=test_user_id
TEST_TENANT=test_tenant_id

# LLM Server Connectivity
LLM_SERVER_URL=http://localhost:9999
APP_DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# LLM Provider Configuration
LLM_PROVIDER=bedrock
LLM_MODEL_NAME=meta.llama3-1-70b-instruct-v1:0
# LLM_PROVIDER_API_KEY=
# LLM_PROVIDER_API_ENDPOINT=
# LLM_PROVIDER_API_VERSION=
# LLM_PROVIDER_API_TYPE=
# LLM_PROVIDER_REGION=us-west-2

# AWS Configuration (for Bedrock)
AWS_REGION=us-west-2
# aws_access_key_id=
# aws_secret_access_key=

# Embeddings Configuration
EMBEDDINGS_PROVIDER=bedrock
EMBEDDINGS_MODEL_NAME=amazon.titan-embed-text-v2:0
# EMBEDDINGS_PROVIDER_API_ENDPOINT=
# EMBEDDINGS_PROVIDER_API_KEY=
# EMBEDDINGS_PROVIDER_API_VERSION=
# EMBEDDINGS_PROVIDER_REGION=us-west-2

# Email Configuration
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=

# General Configuration
MAX_TOKEN_LENGTH=8192
EMBEDDING_BATCH_SIZE=10
MAX_CONCURRENCY=2
MAX_RETRY_COUNT=5
MAX_RETRY_DURATION=600
INITIAL_WAIT_TIME=1

# OpenTelemetry Configuration
OTEL_SERVICE_NAME=llm-benchmark-server
# OTEL_TRACES_EXPORTER=otlp,console
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_RESOURCE_ATTRIBUTES=service.name=llm-benchmark-server
