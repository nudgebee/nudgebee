# ml-k8s-server local-dev env. Copy to .env and edit as needed.
#   cp ml-k8s-server/.env.example ml-k8s-server/.env
# Values below pair with the default compose stack (docker compose up -d).
#
# ---------- Runtime ----------
# Local-dev (`make run` → `python -m server.app`) honors ML_PORT (main
# Flask app) and HEALTH_PORT (health endpoint). The Dockerfile hardcodes
# 9999/8081 in its gunicorn --bind for prod, so these env vars only
# affect from-source runs.
#
# NOTE: 8008 aligns with the canonical 800X local-dev port map in
# app/.env.example, but consumers (Dockerfile, helm, docker-compose,
# ticket-server's ML_SERVICE_URL, llm-server, llm/benchmark) still
# default to 9999. If you change this, also update the consumer side.
ML_PORT=8008
HEALTH_PORT=8081

# ---------- Database ----------
# Reuses the compose Postgres. Same DSN env services-server uses.
# Required for ML inference + recommendation persistence.
ML_INFERENCE_DATABASE_URL=postgresql://postgres:postgrespassword@127.0.0.1:5432/nudgebee?sslmode=disable
# ML_INFERENCE_TABLE_NAME=ml_inference
# ML_DB_POOL_SIZE=5
# ML_DB_MAX_OVERFLOW=5
# ML_DB_POOL_RECYCLE=1800

# ---------- RabbitMQ ----------
# Defaults match the rabbitmq:3-management container in docker-compose.yaml.
# ml-k8s-server consumes from ml-recommendation queue.
RABBIT_MQ_HOST=127.0.0.1
RABBIT_MQ_PORT=5672
RABBIT_MQ_USERNAME=guest
RABBIT_MQ_PASSWORD=guest
# ML_RECOMMENDATION_QUEUE=ml-recommendation
# ML_RECOMMENDATION_EXCHANGE=ml-recommendation

# ---------- Relay server ----------
# Endpoint that ml-k8s-server calls to fetch cluster metrics for inference.
# Must match RELAY_SERVER_ENDPOINT in app/.env.example (http://127.0.0.1:8006).
RELAY_SERVER_ENDPOINT=http://127.0.0.1:8006
RELAY_SERVER_SECRET_KEY=

# ---------- Model storage ----------
# "file" stores trained models on the local filesystem (ML_FILE_BASE_PATH,
# default tempdir). Set to "s3" + ML_MODEL_STORE_BUCKET for S3.
ML_MODEL_STORE_PROVIDER=file
# ML_MODEL_STORE_BUCKET=
# ML_FILE_BASE_PATH=/tmp

# ---------- Tunables (all optional) ----------
# Anomaly detection algorithm: ISOLATION_TREE (default), Z_SCORE, IQR, etc.
# ANOMALY_ALGO=ISOLATION_TREE
# KRR_MAX_CONCURRENT_RELAY_REQUESTS=10
# KRR_OWNER_BATCH_SIZE=100

# ---------- Observability ----------
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER=
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# OTEL_SERVICE_NAME=ml-k8s-server
